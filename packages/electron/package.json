{
  "name": "@buzze/electron",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "electron .",
    "build:bundle": "node esbuild.config.mjs",
    "build:tsc": "tsc",
    "build": "pnpm build:bundle && pnpm build:tsc",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist dist-electron resources/server-bundle.mjs"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "@buzze/client": "workspace:*",
    "@buzze/server": "workspace:*",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.25.0",
    "electron": "^38.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  }
}
